# Production: 빈 값으로 두면 client/SSR fetch 가 상대 경로 /api/* 사용 →
# Vercel server 의 rewrites 가 Fly 백엔드로 forward → Set-Cookie 가 Vercel
# origin 에 저장 (cross-origin 쿠키 read 불가 회피).
# Dev: 백엔드 직접 가리키려면 http://localhost:8001 같은 절대 URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Server-only (production). Vercel rewrites destination. 클라이언트 노출 X.
# 미설정 시 NEXT_PUBLIC_API_BASE_URL 로 fallback (dev 호환).
API_BASE_URL=

NEXT_PUBLIC_FEATURED_RUN_ID=
REVALIDATE_SECRET=replace-me
